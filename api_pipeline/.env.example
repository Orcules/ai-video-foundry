# Video Generation API — Environment Variables
# ==============================================

# Supabase — required for real jobs + Studio sign-in / cloud sessions / gallery
# Project URL + anon public key (Settings → API → Project URL + anon public).
# Use either name below (same value); the server and /api/config accept both.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
# If you only set one key, use SUPABASE_PUBLISHABLE_KEY OR SUPABASE_ANON_KEY (not both required).
# Service role: required for Video Studio gallery (insert user_videos on job completion). Keep secret server-side only.
SUPABASE_SERVICE_ROLE_KEY=
# 1 (default): full login screen before Studio. 0: wizard open immediately; header shows Cloud account strip (Sign in / My videos) when SUPABASE_URL + anon key are set.
# STUDIO_REQUIRE_LOGIN=0

# Video Studio: optional. If set to an existing api_tenants.api_key (sk-tvd-...), signed-in Studio users
# (valid X-Studio-User-Token / ?studio_user_token=) can call the API without pasting the key in the header.
# STUDIO_FALLBACK_API_KEY=sk-tvd-your-tenant-...
# If unset: signed-in Studio users still work when SUPABASE_SERVICE_ROLE_KEY is set and exactly ONE active
# row exists in api_tenants (server picks that api_key automatically).
# After migrations/000_video_pipeline_bootstrap.sql, default tenant key is sk-tvd-studio-bootstrap-orcules (rotate in prod).
# STUDIO_FALLBACK_API_KEY=sk-tvd-studio-bootstrap-orcules

# Pipeline concurrency (default: 2 concurrent video jobs)
MAX_PIPELINE_WORKERS=2

# --- API Keys ---
# These are needed by the monolith (tvd_pipeline) at runtime.
# The wrapper itself only needs GCS + Mux keys.

# OPENAI_API_KEY=sk-...
# KIE_API=...
# ELEVEN_LABS_API_KEY=sk_...
# RENDI_API_KEY=...
# ZAPCAP_API_KEY=...
# ZAPCAP_TEMPLATE_ID=...

# Mux CDN (optional — final video upload)
# MUX_TOKEN_ID=...
# MUX_TOKEN_SECRET=...

# Simulation mode playback ID (optional — for realistic dashboard preview)
# SIM_MUX_PLAYBACK_ID=...

# GCS credentials (path to service_account.json)
# SERVICE_ACCOUNT_FILE=service_account.json
# GCS_CREDENTIALS_FILE=service_account.json

# Optional: in-memory ring buffer for GET /api/admin/server-logs/recent and /stream (SSE).
# Same auth as the API (Bearer or ?token= sk-tvd). Default 8000 lines.
# SERVER_LOG_BUFFER_LINES=8000
